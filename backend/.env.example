NODE_ENV=development
PORT=5000
APP_NAME=CRM Backend
API_PREFIX=/api/v1
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=crm
CORS_ORIGIN=http://localhost:3000
JWT_ACCESS_SECRET=replace-with-access-secret
JWT_ACCESS_EXPIRES_IN=15m
